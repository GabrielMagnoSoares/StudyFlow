generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Activity {
  id        String    @id @default(uuid())

  act_name  String
  subject   String    // “Matéria”. Se depois quiser normalizar, vira Subject model.
  dueAt     DateTime?  // Data+Hora juntas
  priority  Priority  @default(MEDIUM)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // userId    String
  // user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // @@index([userId])
  // @@index([dueAt])
}
